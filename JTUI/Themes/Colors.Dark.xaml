<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- 窗口 -->
	<SolidColorBrush x:Key="JT.Window.Background" Color="#202020"/>
	<SolidColorBrush x:Key="JT.Window.Foreground" Color="#F5F5F5"/>
	<SolidColorBrush x:Key="JT.Window.Border" Color="#3A3A3A"/>

	<!-- 标题栏 -->
	<SolidColorBrush x:Key="JT.TitleBar.Background" Color="#2B2B2B"/>
	<SolidColorBrush x:Key="JT.TitleBar.Foreground" Color="#F5F5F5"/>

	<!-- 标题栏按钮 -->
	<SolidColorBrush x:Key="JT.CaptionButton.Foreground" Color="#F5F5F5"/>
	<SolidColorBrush x:Key="JT.CaptionButton.HoverBackground" Color="#3A3A3A"/>
	<SolidColorBrush x:Key="JT.CaptionButton.PressedBackground" Color="#4A4A4A"/>

	<!-- 关闭按钮(红色保持一致) -->
	<SolidColorBrush x:Key="JT.CloseButton.HoverBackground" Color="#E81123"/>
	<SolidColorBrush x:Key="JT.CloseButton.PressedBackground" Color="#C50F1F"/>


	<!-- 滚动条 -->
	<SolidColorBrush x:Key="JT.ScrollBar.Background" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.ScrollBar.Thumb" Color="#2D2D2D"/>
	<SolidColorBrush x:Key="JT.ScrollBar.ThumbHover" Color="#5E5E5E"/>
	<SolidColorBrush x:Key="JT.ScrollBar.ThumbPressed" Color="#727272"/>

    <!-- 按钮 -->
    <SolidColorBrush x:Key="JT.Button.Background" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="JT.Button.Foreground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.Button.Border" Color="#4A4A4A"/>
    <SolidColorBrush x:Key="JT.Button.HoverBackground" Color="#383838"/>
    <SolidColorBrush x:Key="JT.Button.HoverBorder" Color="#4CC2FF"/>
    <SolidColorBrush x:Key="JT.Button.PressedBackground" Color="#252525"/>
    <SolidColorBrush x:Key="JT.Button.DisabledBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="JT.Button.DisabledForeground" Color="#6A6A6A"/>

    <!-- 开关 -->
    <SolidColorBrush x:Key="JT.Toggle.Accent" Color="#6A6A6A"/>
    <SolidColorBrush x:Key="JT.Toggle.OffBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.Toggle.OnThumb" Color="#202020"/>



    <!-- 图标按钮 -->
    <SolidColorBrush x:Key="JT.IconButton.Foreground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.IconButton.HoverBackground" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="JT.IconButton.PressedBackground" Color="#4A4A4A"/>

    <!-- 提示框 ToolTip -->
    <SolidColorBrush x:Key="JT.ToolTip.Background" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="JT.ToolTip.Foreground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.ToolTip.Border" Color="#4A4A4A"/>


    <!-- 文本框 -->
    <SolidColorBrush x:Key="JT.TextBox.Background" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.TextBox.Foreground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.TextBox.Border" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="JT.TextBox.HoverBorder" Color="#6A6A6A"/>
    <SolidColorBrush x:Key="JT.TextBox.FocusBorder" Color="#000"/>
    <SolidColorBrush x:Key="JT.TextBox.Placeholder" Color="#8A8A8A"/>
    <SolidColorBrush x:Key="JT.TextBox.DisabledBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="JT.TextBox.DisabledForeground" Color="#6A6A6A"/>


    <!-- 菜单 -->
    <SolidColorBrush x:Key="JT.Menu.Background" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="JT.Menu.Foreground" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="JT.Menu.HoverBackground" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="JT.Menu.PopupBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="JT.Menu.PopupBorder" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.Menu.Separator" Color="#3a3a3a"/>
    <SolidColorBrush x:Key="JT.Menu.DisabledForeground" Color="#756a6a6a"/>


    <!-- 数字输入框 -->
    <SolidColorBrush x:Key="JT.NumberBox.Background" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="JT.NumberBox.Foreground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.NumberBox.Border" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.NumberBox.HoverBackground" Color="#383838"/>
    <SolidColorBrush x:Key="JT.NumberBox.HoverBorder" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.NumberBox.DisabledBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="JT.NumberBox.DisabledForeground" Color="#6A6A6A"/>


    <!-- 下拉菜单 -->
    <SolidColorBrush x:Key="JT.ComboBox.Background" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="JT.ComboBox.Foreground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.ComboBox.Border" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="JT.ComboBox.HoverBorder" Color="#6A6A6A"/>
    <SolidColorBrush x:Key="JT.ComboBox.FocusBorder" Color="#b1b1b1"/>
    <SolidColorBrush x:Key="JT.ComboBox.Arrow" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="JT.ComboBox.Placeholder" Color="#8A8A8A"/>
    <SolidColorBrush x:Key="JT.ComboBox.DisabledBackground" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="JT.ComboBox.DisabledForeground" Color="#6A6A6A"/>


    <!-- 标签 Tag -->
    <SolidColorBrush x:Key="JT.Tag.Background" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="JT.Tag.Foreground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.Tag.HoverBackground" Color="#4A4A4A"/>
    <SolidColorBrush x:Key="JT.Tag.DeleteForeground" Color="#C0C0C0"/>
    <SolidColorBrush x:Key="JT.Tag.DeleteHoverBackground" Color="#E81123"/>

    <!-- 图片瀑布流 -->
    <SolidColorBrush x:Key="JT.ImageGrid.Background" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="JT.ImageGrid.CellBackground" Color="#2D2D2D"/>



</ResourceDictionary>
