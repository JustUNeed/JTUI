<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:JTUI.Controls.FileGrid"
    xmlns:imggrid="clr-namespace:JTUI.Controls.ImageGrid"
    xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel">


    <!-- 复用 ImageGrid 里的 converter 类,但在本字典内各建一份实例 -->
    <imggrid:HalfThicknessConverter x:Key="JT.HalfThicknessConverter"/>
    <imggrid:SquareSizeConverter   x:Key="JT.SquareSizeConverter"/>

        
        <!-- 单个文件项:上图标 + 下名称 -->
    <DataTemplate x:Key="JT.FileItem.Template">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 图标 -->
            <Image Grid.Row="0"
                   Source="{Binding Icon}"
                   Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType={x:Type controls:JTFileGrid}}}"
                   Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType={x:Type controls:JTFileGrid}}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            
            <!-- 名称:最多两行,居中,省略号 -->
            <TextBlock Grid.Row="1"
                       Text="{Binding DisplayName}"
                       Foreground="{DynamicResource JT.Foreground}"
                       FontSize="12"
                       Margin="2,4,2,2"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"
                       MaxHeight="16"
                       ToolTip="{Binding Path}"/>

            <!-- 删除按钮 -->
            <Button x:Name="DeleteBtn"
                    Grid.Row="0"
                    Tag="{Binding}"
                    Width="20" Height="20" Margin="4"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Visibility="Collapsed" Cursor="Hand"
                    Content="&#xE711;"
                    FontFamily="Segoe MDL2 Assets" FontSize="10"
                    Foreground="White">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#CC000000" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <DataTemplate.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsMouseOver,
                        RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                    <Condition Binding="{Binding ShowDeleteButton,
                        RelativeSource={RelativeSource AncestorType={x:Type controls:JTFileGrid}}}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter TargetName="DeleteBtn" Property="Visibility" Value="Visible"/>
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- 主控件样式 -->
    <Style TargetType="{x:Type controls:JTFileGrid}">
        <Setter Property="Background" Value="{DynamicResource JT.ImageGrid.Background}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingPanel.CacheLength" Value="2"/>
        <Setter Property="VirtualizingPanel.CacheLengthUnit" Value="Page"/>
        <Setter Property="ItemTemplate" Value="{StaticResource JT.FileItem.Template}"/>

        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <vwp:VirtualizingWrapPanel
                        Orientation="Horizontal"
                        SpacingMode="StartAndEndOnly"
                        StretchItems="False"
                        ItemSize="{Binding ColumnWidth,
                            RelativeSource={RelativeSource AncestorType={x:Type controls:JTFileGrid}},
                            Converter={StaticResource JT.SquareSizeConverter}}"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin"
                            Value="{Binding ItemSpacing,
                                RelativeSource={RelativeSource AncestorType={x:Type controls:JTFileGrid}},
                                Converter={StaticResource JT.HalfThicknessConverter}}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid>
                                    <Border x:Name="Root" Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <Border x:Name="Highlight"
                                            CornerRadius="4"
                                            BorderThickness="2"
                                            BorderBrush="Transparent"
                                            Background="Transparent"
                                            IsHitTestVisible="False"
                                            SnapsToDevicePixels="True"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Highlight" Property="Background" Value="#1A808080"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Highlight" Property="BorderBrush"
                                                Value="{DynamicResource JT.Accent}"/>
                                        <Setter TargetName="Highlight" Property="Background" Value="#22808080"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseCaptureWithin" Value="True">
                                        <Setter TargetName="Highlight" Property="Background" Value="#33000000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:JTFileGrid}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Focusable="False"
                                      CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                      HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                      VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                      Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
