<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:JTUI.Controls">

    <Style TargetType="{x:Type controls:JTNumberBox}">
        <Setter Property="Background" Value="{DynamicResource JT.NumberBox.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource JT.NumberBox.Foreground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource JT.NumberBox.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinWidth" Value="60"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:JTNumberBox}">
                    <!-- 外层统一负责:边框 / 背景 / 圆角 / 内边距(切换时尺寸不变) -->
                    <Border x:Name="OuterBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Cursor="SizeWE"
                            SnapsToDevicePixels="True">
                        <Grid Margin="{TemplateBinding Padding}">
                            <!-- 显示态:Label 靠左,数值 + 单位靠右 -->
                            <DockPanel x:Name="DisplayPanel" LastChildFill="False">
                                <TextBlock x:Name="LabelText"
                                           DockPanel.Dock="Left"
                                           Text="{TemplateBinding Label}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                                <TextBlock x:Name="ValueText"
                                        
                                           DockPanel.Dock="Right"
                                           Text="{TemplateBinding ValueDisplayText}"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                            </DockPanel>

                            <!-- 编辑态:复用 JTTextBox,无边框无内距,右对齐 -->
                            <controls:JTTextBox x:Name="PART_TextBox"
                                                BorderThickness="0"
                                                Padding="0"
                                                Background="Transparent"
                                                CornerRadius="0"
                                                FontSize="{TemplateBinding FontSize}"
                                                VerticalContentAlignment="Center"
                                                HorizontalContentAlignment="Right"
                                                Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- 悬停:边框高亮 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush"
                                    Value="{DynamicResource JT.NumberBox.HoverBorder}"/>
                            <Setter TargetName="OuterBorder" Property="Background"
                                    Value="{DynamicResource JT.NumberBox.HoverBackground}"/>
                        </Trigger>

                        <!-- 编辑态:隐藏显示层,露出文本框 -->
                        <Trigger Property="IsEditing" Value="True">
                            <Setter TargetName="DisplayPanel" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="PART_TextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="OuterBorder" Property="Cursor" Value="IBeam"/>
                        </Trigger>

                        <!-- 禁用 -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="OuterBorder" Property="Background"
                                    Value="{DynamicResource JT.NumberBox.DisabledBackground}"/>
                            <Setter TargetName="OuterBorder" Property="Cursor" Value="Arrow"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource JT.NumberBox.DisabledForeground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
