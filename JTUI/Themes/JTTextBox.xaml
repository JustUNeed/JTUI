<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:JTUI.Controls">

    <Style TargetType="{x:Type controls:JTTextBox}">
        <Setter Property="Background" Value="{DynamicResource JT.TextBox.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource JT.TextBox.Foreground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource JT.TextBox.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CaretBrush" Value="{DynamicResource JT.TextBox.Foreground}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource JT.TextBox.FocusBorder}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ContextMenu" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:JTTextBox}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- 占位提示文字 -->
                            <TextBlock x:Name="Placeholder"
                                       Text="{TemplateBinding Placeholder}"
                                       Foreground="{DynamicResource JT.TextBox.Placeholder}"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>

                            <!-- 文本承载区(部件名固定) -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- 文本为空时显示占位 -->
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>

                        <!-- 悬停:边框略加深 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource JT.TextBox.HoverBorder}"/>
                        </Trigger>

                        <!-- 聚焦:边框高亮(代替系统蓝色焦点框) -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource JT.TextBox.FocusBorder}"/>
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <!-- 禁用 -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource JT.TextBox.DisabledBackground}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource JT.TextBox.DisabledForeground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
