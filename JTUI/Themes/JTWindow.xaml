<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:controls="clr-namespace:JTUI.Controls">

    <!-- ============ 标题栏按钮:最小化(灰色高亮) ============ -->
    <Style x:Key="JTCaptionButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource JT.CaptionButton.Foreground}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource JT.CaptionButton.HoverBackground}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource JT.CaptionButton.PressedBackground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ 标题栏按钮:关闭(红色高亮 + 白色图标) ============ -->
    <Style x:Key="JTCloseButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource JT.CaptionButton.Foreground}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}">
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource JT.CloseButton.HoverBackground}"/>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource JT.CloseButton.PressedBackground}"/>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ JTWindow 默认样式 ============ -->
    <Style TargetType="{x:Type controls:JTWindow}">
        <Setter Property="Background" Value="{DynamicResource JT.Window.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource JT.Window.Foreground}"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:JTWindow}">
                    <Border x:Name="RootBorder"
        Background="{TemplateBinding Background}"
        BorderBrush="{DynamicResource JT.Window.Border}"
        BorderThickness="1"
        Padding="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="TitleRow" Height="30"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 内容区 -->
                            <ContentPresenter x:Name="ContentHost"
                              Grid.Row="1"
                              Content="{TemplateBinding Content}"/>

                            <!-- 标题栏背景 + 标题文字(常规模式用;沉浸模式透明) -->
                            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Background="{DynamicResource JT.TitleBar.Background}">
                                <TextBlock x:Name="TitleText"
                           Text="{TemplateBinding Title}"
                           Foreground="{DynamicResource JT.TitleBar.Foreground}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="12,0,0,0"
                           FontSize="13"/>
                            </Grid>

                            <!-- 三个按钮:独立提到最上层,永远贴右上角,永远可点 -->
                            <StackPanel x:Name="CaptionButtons"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Panel.ZIndex="100"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button x:Name="PART_MinButton"
                        Style="{StaticResource JTCaptionButtonStyle}"
                        ToolTip="最小化"
                        Content="&#xE921;"/>
                                <Button x:Name="PART_MaxButton"
                        Style="{StaticResource JTCaptionButtonStyle}"
                        ToolTip="最大化"
                        Content="&#xE922;"/>
                                <Button x:Name="PART_CloseButton"
                        Style="{StaticResource JTCloseButtonStyle}"
                        ToolTip="关闭"
                        Content="&#xE8BB;"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- 无标题栏:连按钮也去掉 -->
                        <Trigger Property="TitleBarMode" Value="NoTitleBar">
                            <!-- 去掉浅边线,纯背景色 -->
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="0"/>
                            
                            <Setter TargetName="TitleBar" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="CaptionButtons" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TitleRow" Property="Height" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.Row" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.RowSpan" Value="2"/>
                        </Trigger>

                        <!-- 沉浸:标题行归零、内容铺满;标题栏透明、标题文字隐藏;按钮保留 -->
                        <Trigger Property="TitleBarMode" Value="Immersive">
                            <Setter TargetName="TitleRow" Property="Height" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.Row" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.RowSpan" Value="2"/>

                            <Setter TargetName="TitleBar" Property="Background" Value="Transparent"/>
                            <Setter TargetName="TitleBar" Property="Height" Value="30"/>
                            <Setter TargetName="TitleBar" Property="VerticalAlignment" Value="Top"/>
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed"/>
                            <!-- CaptionButtons 不动,本来就在最上层 -->
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>
