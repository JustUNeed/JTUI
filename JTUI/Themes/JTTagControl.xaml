<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:JTUI.Controls">

    <Style TargetType="{x:Type controls:JTTagControl}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:JTTagControl}">
                    <Border Background="{TemplateBinding Background}"
            SnapsToDevicePixels="True">
                        <WrapPanel Orientation="Horizontal">
                            <!-- 已有标签 -->
                            <ItemsPresenter/>

                            <!-- 加号按钮:风格与 tag 一致的小胶囊 -->
                            <Border x:Name="PART_AddButton"
                    
                    Background="Transparent"
                    CornerRadius="0"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    SnapsToDevicePixels="True">
                                <Grid   Margin="4" Width="12" Height="12">
                                    <Path Width="10" Height="10"
                          Stretch="Fill"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Stroke="{DynamicResource JT.Tag.Foreground}"
                          StrokeThickness="1.4"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 0,0.5 L 1,0.5 M 0.5,0 L 0.5,1"/>
                                </Grid>
                            </Border>

                            <!-- 临时输入框:外观与 tag 完全一致(同背景/圆角/内边距),默认隐藏 -->
                            <Border x:Name="PART_InputHost"
                
                    Background="{DynamicResource JT.Tag.Background}"
                    CornerRadius="0"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    SnapsToDevicePixels="True">
                                <controls:JTTextBox x:Name="PART_Input"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="8,3,8,3"
                                    MinWidth="50"
                                    Background="Transparent"
                                    FontSize="{TemplateBinding FontSize}"
                                    VerticalContentAlignment="Center"/>
                            </Border>
                        </WrapPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="AllowAdd" Value="False">
                            <Setter TargetName="PART_AddButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
