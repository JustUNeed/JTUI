<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:v="clr-namespace:JTUI.Controls.Viewer">

    <Style TargetType="{x:Type v:JTImageViewer}">
        <Setter Property="Background" Value="{DynamicResource JT.ImageGrid.Background}"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type v:JTImageViewer}">
                    <Grid x:Name="PART_Container"
                          Background="{TemplateBinding Background}"
                          ClipToBounds="True">
                        <!-- 图片:RenderTransform 由控件接管 -->
                        <Image x:Name="PART_Image"
       RenderTransformOrigin="0,0"
       Stretch="Uniform"
       SnapsToDevicePixels="True"/>

                
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
