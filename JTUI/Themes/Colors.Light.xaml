<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- 窗口 -->
	<SolidColorBrush x:Key="JT.Window.Background" Color="#FFFFFF"/>
	<SolidColorBrush x:Key="JT.Window.Foreground" Color="#1A1A1A"/>
	<SolidColorBrush x:Key="JT.Window.Border" Color="#DDDDDD"/>

	<!-- 标题栏 -->
	<SolidColorBrush x:Key="JT.TitleBar.Background" Color="#F3F3F3"/>
	<SolidColorBrush x:Key="JT.TitleBar.Foreground" Color="#1A1A1A"/>

	<!-- 标题栏按钮(最小化/最大化) -->
	<SolidColorBrush x:Key="JT.CaptionButton.Foreground" Color="#1A1A1A"/>
	<SolidColorBrush x:Key="JT.CaptionButton.HoverBackground" Color="#E5E5E5"/>
	<SolidColorBrush x:Key="JT.CaptionButton.PressedBackground" Color="#CCCCCC"/>

	<!-- 关闭按钮(红色固定,不随主题变) -->
	<SolidColorBrush x:Key="JT.CloseButton.HoverBackground" Color="#E81123"/>
	<SolidColorBrush x:Key="JT.CloseButton.PressedBackground" Color="#C50F1F"/>


	<!-- 滚动条 -->
	<SolidColorBrush x:Key="JT.ScrollBar.Background" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.ScrollBar.Thumb" Color="#e5e5e5"/>
	<SolidColorBrush x:Key="JT.ScrollBar.ThumbHover" Color="#A6A6A6"/>
	<SolidColorBrush x:Key="JT.ScrollBar.ThumbPressed" Color="#8A8A8A"/>


    <!-- 按钮 -->
    <SolidColorBrush x:Key="JT.Button.Background" Color="#e5e5e5"/>
    <SolidColorBrush x:Key="JT.Button.Foreground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="JT.Button.Border" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="JT.Button.HoverBackground" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="JT.Button.HoverBorder" Color="#0067C0"/>
    <SolidColorBrush x:Key="JT.Button.PressedBackground" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="JT.Button.DisabledBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.Button.DisabledForeground" Color="#A0A0A0"/>

    <!-- 开关 -->
    <SolidColorBrush x:Key="JT.Toggle.Accent" Color="#828282"/>
    <SolidColorBrush x:Key="JT.Toggle.OffBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.Toggle.OnThumb" Color="#FFFFFF"/>



    <!-- 图标按钮 -->
    <SolidColorBrush x:Key="JT.IconButton.Foreground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="JT.IconButton.HoverBackground" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="JT.IconButton.PressedBackground" Color="#D5D5D5"/>

    <!-- 提示框 ToolTip -->
    <SolidColorBrush x:Key="JT.ToolTip.Background" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="JT.ToolTip.Foreground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="JT.ToolTip.Border" Color="#CCCCCC"/>


    <!-- 文本框 -->
    <SolidColorBrush x:Key="JT.TextBox.Background" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="JT.TextBox.Foreground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="JT.TextBox.Border" Color="#828282"/>
    <SolidColorBrush x:Key="JT.TextBox.HoverBorder" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="JT.TextBox.FocusBorder" Color="#000"/>
    <SolidColorBrush x:Key="JT.TextBox.Placeholder" Color="#9A9A9A"/>
    <SolidColorBrush x:Key="JT.TextBox.DisabledBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.TextBox.DisabledForeground" Color="#A0A0A0"/>


    <!-- 菜单 -->
    <SolidColorBrush x:Key="JT.Menu.Background" Color="#b1b1b1"/>
    <SolidColorBrush x:Key="JT.Menu.Foreground" Color="#5A5A5A"/>
    <SolidColorBrush x:Key="JT.Menu.HoverBackground" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="JT.Menu.PopupBackground" Color="#f3f3f3"/>
    <SolidColorBrush x:Key="JT.Menu.PopupBorder" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.Menu.Separator" Color="#DADADA"/>
    <SolidColorBrush x:Key="JT.Menu.DisabledForeground" Color="#A0A0A0"/>

    <!-- 数字输入框 -->
    <SolidColorBrush x:Key="JT.NumberBox.Background" Color="#e5e5e5"/>
    <SolidColorBrush x:Key="JT.NumberBox.Foreground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="JT.NumberBox.Border" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.NumberBox.HoverBackground" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="JT.NumberBox.HoverBorder" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.NumberBox.DisabledBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.NumberBox.DisabledForeground" Color="#A0A0A0"/>


    <!-- 下拉菜单 -->
    <SolidColorBrush x:Key="JT.ComboBox.Background" Color="#e5e5e5"/>
    <SolidColorBrush x:Key="JT.ComboBox.Foreground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="JT.ComboBox.Border" Color="Transparent"/>
    <SolidColorBrush x:Key="JT.ComboBox.HoverBorder" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="JT.ComboBox.FocusBorder" Color="#000000"/>
    <SolidColorBrush x:Key="JT.ComboBox.Arrow" Color="#6A6A6A"/>
    <SolidColorBrush x:Key="JT.ComboBox.Placeholder" Color="#9A9A9A"/>
    <SolidColorBrush x:Key="JT.ComboBox.DisabledBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.ComboBox.DisabledForeground" Color="#A0A0A0"/>


    <!-- 标签 Tag -->
    <SolidColorBrush x:Key="JT.Tag.Background" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="JT.Tag.Foreground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="JT.Tag.HoverBackground" Color="#D5D5D5"/>
    <SolidColorBrush x:Key="JT.Tag.DeleteForeground" Color="#fff"/>
    <SolidColorBrush x:Key="JT.Tag.DeleteHoverBackground" Color="#E81123"/>

    <!-- 图片瀑布流 -->
    <SolidColorBrush x:Key="JT.ImageGrid.Background" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="JT.ImageGrid.CellBackground" Color="#E8E8E8"/>


</ResourceDictionary>
